# Copy to secrets.yaml (HA) and esphome/devices/secrets.yaml (ESPHome), then fill in.
# NEVER commit the real files — both are gitignored.

# --- WiFi (ESPHome boards) ---
wifi_ssid: "MyNetwork"
wifi_password: "wifi-password-here"
fallback_ap_password: "fallback-ap-password"

# --- ESPHome ---
# Generate a real 32-byte base64 key: https://esphome.io/components/api.html
# (or run: openssl rand -base64 32)
api_encryption_key: "RVhBTVBMRS1LRVktUkVQTEFDRS1NRS0wMTIzNDU2Nzg="
ota_password: "ota-password-here"

# --- MQTT (Mosquitto add-on user) ---
mqtt_username: "mqtt"
mqtt_password: "mqtt-password-here"

# --- Email alerts (SMTP2GO) ---
smtp2go_username: "smtp2go-username-here"
smtp2go_password: "smtp2go-password-here"
alert_sender: "alerts@example.com"
alert_email_scott: "scott@example.com"
