# Secrets — NEVER commit
secrets.yaml
esphome/secrets.yaml

# Zigbee2MQTT add-on data dir (runtime-managed; contains the network key).
# Reference config lives in docs/zigbee2mqtt-reference.yaml.
zigbee2mqtt/

# Home Assistant runtime state
.storage/
.cloud/
.HA_VERSION
.uuid
home-assistant.log*
home-assistant_v2.db*
zigbee.db*
deps/
tts/
backups/
blueprints/
image/
www/community/

# HACS + HACS-managed custom integrations (e.g. Vivint).
# HACS self-updates and its components live on the box only, outside GitOps —
# they must not be vendored/version-pinned in this repo. Untracked files
# survive the Git pull add-on's pull/reset; this also keeps them out of any
# future `git clean`.
custom_components/

# ESPHome build artifacts
esphome/.esphome/
.esphome/

# OS / editor
.DS_Store
Thumbs.db
__pycache__/
